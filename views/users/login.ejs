<% layout('/layouts/boilerplate') %>

    <div class="row mt-3">
        <h1 class="col-6 offset-3">Log In to Travique</h1>
        <div class="col-8 offset-2">

            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input name="username" id="username" placeholder="Enter a username" type="text" class="form-control"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                </div>
                
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input name="password" id="password" placeholder="Enter a password" type="password" class="form-control"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                </div>
                <button type="submit" class="btn btn-success">Log In</button>
            </form>
        </div>
    </div>